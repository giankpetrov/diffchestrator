      {
        "id": "diffchestrator.welcome",
        "title": "Get Started with Diffchestrator",
        "description": "Set up multi-repo Git orchestration in a few steps.",
        "steps": [
          {
            "id": "diffchestrator.welcome.intro",
            "title": "Welcome to Diffchestrator",
            "description": "Multi-repo Git orchestration built for Claude Code.\n\n[Open Dashboard](command:diffchestrator.dashboard)",

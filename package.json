    "configuration": {
      "title": "Diffchestrator",
      "properties": {
        "diffchestrator.scanRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Root directories to scan for Git repositories"
        },
        "diffchestrator.scanMaxDepth": {
          "type": "number",
          "default": 6,
          "description": "Maximum directory depth when scanning for repositories"
        },
        "diffchestrator.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan for repositories when VS Code starts"
        },
        "diffchestrator.changedOnlyDefault": {
          "type": "boolean",
          "default": false,
          "description": "Show only repos with changes by default"
        },
        "diffchestrator.autoRefreshInterval": {
          "type": "number",
          "default": 10,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        },
        "diffchestrator.favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Favorited repository paths"
        },
        "diffchestrator.showFavorites": {
          "type": "boolean",
          "default": true,
          "description": "Show favorites in the Active Repos view"
        },
        "diffchestrator.fetchOnScan": {
          "type": "boolean",
          "default": false,
          "description": "Automatically git fetch during scan to show accurate ahead/behind counts"
        },
        "diffchestrator.autoPushAfterCommit": {
          "type": "boolean",
          "default": false,
          "description": "Automatically push after a successful commit via Alt+D, M"
        },
        "diffchestrator.repoTags": {
          "type": "object",
          "default": {},
          "description": "Repo tags for filtering (managed by extension)"
        },
        "diffchestrator.snapshots": {
          "type": "object",
          "default": {},
          "description": "Workspace snapshots (managed by extension)"
        },
        "diffchestrator.claudePermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "full"
          ],
          "default": "acceptEdits",
          "description": "Permission mode for Claude Code AI commits"
        },
        "diffchestrator.scanExtraSkipDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directory names to skip during scanning"
        },
        "diffchestrator.showInlineBlame": {
          "type": "boolean",
          "default": true,
          "description": "Show inline git blame annotation on the current line"
        },
        "diffchestrator.pinnedRepos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Repository paths pinned to the top of Dashboard Sync Overview"
        }

            "media": {
              "image": "resources/icons/icon.png",
              "altText": "Scan repos"
            },
            "completionEvents": [
              "onCommand:diffchestrator.scan"
            ]
          },
          {
            "id": "diffchestrator.welcome.shortcuts",
            "title": "Learn the Shortcuts",
            "description": "All shortcuts use **Alt+D** as a chord prefix.\n\n**Alt+D, R** Switch repo | **Alt+D, C** AI Commit | **Alt+D, V** Dashboard\n\n[View All Shortcuts](command:diffchestrator.showShortcuts)",
            "media": {
              "image": "resources/icons/icon.png",

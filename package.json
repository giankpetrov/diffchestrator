{
  "name": "diffchestrator",
  "displayName": "Diffchestrator",
  "description": "Multi-repo Git orchestration built for Claude Code — AI commits, diffs, and terminal integration",
  "version": "0.62.0",
  "publisher": "andrevops-com",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andrevops/diffchestrator"
  },
  "bugs": {
    "url": "https://github.com/Andrevops/diffchestrator/issues"
  },
  "homepage": "https://github.com/Andrevops/diffchestrator#readme",
  "keywords": [
    "git",
    "multi-repo",
    "claude",
    "diff",
    "monorepo"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/license/Andrevops/diffchestrator",
      "href": "https://github.com/Andrevops/diffchestrator/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "activationEvents": [
    "onView:diffchestrator.repos",
    "onView:diffchestrator.activeRepos",
    "onView:diffchestrator.changedFiles",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diffchestrator",
          "title": "Diffchestrator",
          "icon": "resources/icons/diffchestrator.svg"
        }
      ]
    },
    "views": {
      "diffchestrator": [
        {
          "id": "diffchestrator.activeRepos",
          "name": "Active Repos"
        },
        {
          "id": "diffchestrator.changedFiles",
          "name": "Changed Files"
        },
        {
          "id": "diffchestrator.repos",
          "name": "Repositories"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "diffchestrator.repos",
        "contents": "No repositories found.\n[Scan Directory](command:diffchestrator.scan)",
        "when": "!diffchestrator.hasRepos"
      },
      {
        "view": "diffchestrator.changedFiles",
        "contents": "Click a repository to see its changed files.",
        "when": "!diffchestrator.hasSelectedRepo"
      }
    ],
    "commands": [
      {
        "command": "diffchestrator.scan",
        "title": "Scan for Repositories",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.rescan",
        "title": "Rescan Repositories",
        "category": "Diffchestrator",
        "icon": "$(refresh)"
      },
      {
        "command": "diffchestrator.toggleChangedOnly",
        "title": "Toggle Changed Only",
        "category": "Diffchestrator",
        "icon": "$(filter)"
      },
      {
        "command": "diffchestrator.toggleFavorite",
        "title": "Toggle Favorite",
        "category": "Diffchestrator",
        "icon": "$(star)"
      },
      {
        "command": "diffchestrator.grepInRepo",
        "title": "Search in Repo",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.grepActiveRepos",
        "title": "Search Active Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.grepAllRepos",
        "title": "Search All Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.closeActiveRepo",
        "title": "Close Active Repo",
        "category": "Diffchestrator",
        "icon": "$(close)"
      },
      {
        "command": "diffchestrator.closePickedRepo",
        "title": "Close Active Repo (Pick)",
        "category": "Diffchestrator",
        "icon": "$(close-all)"
      },
      {
        "command": "diffchestrator.closeAllActiveRepos",
        "title": "Close All Active Repos",
        "category": "Diffchestrator",
        "icon": "$(close-all)"
      },
      {
        "command": "diffchestrator.nextChangedFile",
        "title": "Next Changed File",
        "category": "Diffchestrator",
        "icon": "$(arrow-down)"
      },
      {
        "command": "diffchestrator.prevChangedFile",
        "title": "Previous Changed File",
        "category": "Diffchestrator",
        "icon": "$(arrow-up)"
      },
      {
        "command": "diffchestrator.searchInRepo",
        "title": "Open Repo in New Window",
        "category": "Diffchestrator",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "diffchestrator.favoriteCurrent",
        "title": "Favorite Current Repo",
        "category": "Diffchestrator",
        "icon": "$(star)"
      },
      {
        "command": "diffchestrator.cycleActiveRepo",
        "title": "Cycle Active Repo",
        "category": "Diffchestrator",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "diffchestrator.viewDiff",
        "title": "View Diff",
        "category": "Diffchestrator",
        "icon": "$(diff)"
      },
      {
        "command": "diffchestrator.viewMultiRepoDiff",
        "title": "View Multi-Repo Diff",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.stageFile",
        "title": "Stage File",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageFile",
        "title": "Unstage File",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.stageAll",
        "title": "Stage All",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageAll",
        "title": "Unstage All",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.commit",
        "title": "Commit",
        "category": "Diffchestrator",
        "icon": "$(check)"
      },
      {
        "command": "diffchestrator.push",
        "title": "Push",
        "category": "Diffchestrator",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "diffchestrator.pull",
        "title": "Pull",
        "category": "Diffchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "diffchestrator.aiCommit",
        "title": "AI Commit (Claude)",
        "category": "Diffchestrator",
        "icon": "$(sparkle)"
      },
      {
        "command": "diffchestrator.bulkCommit",
        "title": "Bulk Commit Selected Repos",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.bulkPush",
        "title": "Bulk Push Selected Repos",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.openClaudeCode",
        "title": "Open Claude Code",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.yolo",
        "title": "Yolo (Claude Sandbox)",
        "category": "Diffchestrator",
        "icon": "$(zap)"
      },
      {
        "command": "diffchestrator.yolonew",
        "title": "Yolonew (Claude Sandbox)",
        "category": "Diffchestrator",
        "icon": "$(zap)"
      },
      {
        "command": "diffchestrator.searchFiles",
        "title": "Search Files Across Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.browseFiles",
        "title": "Browse Files in Repo",
        "category": "Diffchestrator",
        "icon": "$(file-directory)"
      },
      {
        "command": "diffchestrator.switchRepo",
        "title": "Switch Repo",
        "category": "Diffchestrator",
        "icon": "$(repo)"
      },
      {
        "command": "diffchestrator.openTerminal",
        "title": "Open Terminal",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.selectRepo",
        "title": "Select / Deselect Repo",
        "category": "Diffchestrator",
        "icon": "$(check)"
      },
      {
        "command": "diffchestrator.clearSelection",
        "title": "Clear Selection",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.commitHistory",
        "title": "Commit History",
        "category": "Diffchestrator",
        "icon": "$(history)"
      },
      {
        "command": "diffchestrator.discardFile",
        "title": "Discard Changes",
        "category": "Diffchestrator",
        "icon": "$(discard)"
      },
      {
        "command": "diffchestrator.discardAll",
        "title": "Discard All Changes",
        "category": "Diffchestrator",
        "icon": "$(discard)"
      },
      {
        "command": "diffchestrator.stageCurrentFile",
        "title": "Stage This File",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageCurrentFile",
        "title": "Unstage This File",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.switchBranch",
        "title": "Switch Branch",
        "category": "Diffchestrator",
        "icon": "$(git-branch)"
      },
      {
        "command": "diffchestrator.stash",
        "title": "Stash Management",
        "category": "Diffchestrator",
        "icon": "$(archive)"
      },
      {
        "command": "diffchestrator.toggleBlame",
        "title": "Toggle Inline Blame",
        "category": "Diffchestrator",
        "icon": "$(eye)"
      },
      {
        "command": "diffchestrator.fetchAll",
        "title": "Fetch All Repos",
        "category": "Diffchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "diffchestrator.bulkPull",
        "title": "Pull Behind Repos",
        "category": "Diffchestrator",
        "icon": "$(repo-pull)"
      },
      {
        "command": "diffchestrator.claudeReviewAll",
        "title": "Claude Review All Changes",
        "category": "Diffchestrator",
        "icon": "$(sparkle)"
      },
      {
        "command": "diffchestrator.openRootTerminal",
        "title": "Open Terminal at Root",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.switchRoot",
        "title": "Switch Scan Root",
        "category": "Diffchestrator",
        "icon": "$(folder-opened)"
      },
      {
        "command": "diffchestrator.addScanRoot",
        "title": "Add Scan Root",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.removeScanRoot",
        "title": "Remove Scan Root",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.toggleShowFavorites",
        "title": "Toggle Favorites",
        "category": "Diffchestrator",
        "icon": "$(star-full)"
      },
      {
        "command": "diffchestrator.toggleShowFavoritesOff",
        "title": "Toggle Favorites",
        "category": "Diffchestrator",
        "icon": "$(star-empty)"
      },
      {
        "command": "diffchestrator.copyRepoInfo",
        "title": "Copy Repo Info",
        "category": "Diffchestrator",
        "icon": "$(clippy)"
      },
      {
        "command": "diffchestrator.showShortcuts",
        "title": "Show Keyboard Shortcuts",
        "category": "Diffchestrator",
        "icon": "$(keyboard)"
      },
      {
        "command": "diffchestrator.activityLog",
        "title": "Activity Log (All Repos)",
        "category": "Diffchestrator",
        "icon": "$(pulse)"
      },
      {
        "command": "diffchestrator.branchCleanup",
        "title": "Clean Up Merged Branches",
        "category": "Diffchestrator",
        "icon": "$(git-branch)"
      },
      {
        "command": "diffchestrator.openRemoteUrl",
        "title": "Open Remote in Browser",
        "category": "Diffchestrator",
        "icon": "$(link-external)"
      },
      {
        "command": "diffchestrator.setRepoTag",
        "title": "Set Tags",
        "category": "Diffchestrator",
        "icon": "$(tag)"
      },
      {
        "command": "diffchestrator.filterByTag",
        "title": "Filter by Tag",
        "category": "Diffchestrator",
        "icon": "$(tag)"
      },
      {
        "command": "diffchestrator.saveSnapshot",
        "title": "Save Workspace Snapshot",
        "category": "Diffchestrator",
        "icon": "$(bookmark)"
      },
      {
        "command": "diffchestrator.loadSnapshot",
        "title": "Load Workspace Snapshot",
        "category": "Diffchestrator",
        "icon": "$(bookmark)"
      },
      {
        "command": "diffchestrator.undoCommit",
        "title": "Undo Last Commit",
        "category": "Diffchestrator",
        "icon": "$(discard)"
      },
      {
        "command": "diffchestrator.selectAllActive",
        "title": "Select All Active Repos",
        "category": "Diffchestrator",
        "icon": "$(check-all)"
      },
      {
        "command": "diffchestrator.deselectAll",
        "title": "Deselect All",
        "category": "Diffchestrator",
        "icon": "$(close-all)"
      },
      {
        "command": "diffchestrator.swapRepo",
        "title": "Swap to Previous Repo",
        "category": "Diffchestrator",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "diffchestrator.fetchRepo",
        "title": "Fetch",
        "category": "Diffchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "diffchestrator.revealInExplorer",
        "title": "Reveal in File Explorer",
        "category": "Diffchestrator",
        "icon": "$(folder-opened)"
      },
      {
        "command": "diffchestrator.dashboard",
        "title": "Dashboard",
        "category": "Diffchestrator",
        "icon": "$(dashboard)"
      },
      {
        "command": "diffchestrator.cycleTerminal",
        "title": "Cycle Terminal",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.closeTerminal",
        "title": "Close Terminal",
        "category": "Diffchestrator",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diffchestrator.prevChangedFile",
          "group": "navigation@1",
          "when": "diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.nextChangedFile",
          "group": "navigation@2",
          "when": "diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.stageCurrentFile",
          "group": "navigation@3",
          "when": "resourceScheme == file && diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.unstageCurrentFile",
          "group": "navigation@4",
          "when": "resourceScheme == file && diffchestrator.hasSelectedRepo"
        }
      ],
      "view/title": [
        {
          "command": "diffchestrator.toggleShowFavorites",
          "when": "view == diffchestrator.activeRepos && diffchestrator.showFavorites",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.toggleShowFavoritesOff",
          "when": "view == diffchestrator.activeRepos && !diffchestrator.showFavorites",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.selectAllActive",
          "when": "view == diffchestrator.activeRepos",
          "group": "navigation@2"
        },
        {
          "command": "diffchestrator.deselectAll",
          "when": "view == diffchestrator.activeRepos && diffchestrator.hasMultiSelection",
          "group": "navigation@3"
        },
        {
          "command": "diffchestrator.scan",
          "when": "view == diffchestrator.repos",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.rescan",
          "when": "view == diffchestrator.repos",
          "group": "navigation@2"
        },
        {
          "command": "diffchestrator.toggleChangedOnly",
          "when": "view == diffchestrator.repos",
          "group": "navigation@3"
        },
        {
          "command": "diffchestrator.fetchAll",
          "when": "view == diffchestrator.repos",
          "group": "navigation@4"
        },
        {
          "command": "diffchestrator.openRootTerminal",
          "when": "view == diffchestrator.repos",
          "group": "navigation@5"
        },
        {
          "command": "diffchestrator.switchRoot",
          "when": "view == diffchestrator.repos",
          "group": "navigation@6"
        },
        {
          "command": "diffchestrator.dashboard",
          "when": "view == diffchestrator.repos && diffchestrator.hasRepos",
          "group": "navigation@7"
        },
        {
          "command": "diffchestrator.stageAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.unstageAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@2"
        },
        {
          "command": "diffchestrator.discardAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "diffchestrator.viewDiff",
          "when": "viewItem == repo",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.commit",
          "when": "viewItem == repo",
          "group": "inline@2"
        },
        {
          "command": "diffchestrator.push",
          "when": "viewItem == repo",
          "group": "1_actions@1"
        },
        {
          "command": "diffchestrator.pull",
          "when": "viewItem == repo",
          "group": "1_actions@2"
        },
        {
          "command": "diffchestrator.fetchRepo",
          "when": "viewItem == repo",
          "group": "1_actions@3"
        },
        {
          "command": "diffchestrator.aiCommit",
          "when": "viewItem == repo",
          "group": "1_actions@4"
        },
        {
          "command": "diffchestrator.undoCommit",
          "when": "viewItem == repo",
          "group": "1_actions@5"
        },
        {
          "command": "diffchestrator.commitHistory",
          "when": "viewItem == repo",
          "group": "1_actions@6"
        },
        {
          "command": "diffchestrator.switchBranch",
          "when": "viewItem == repo",
          "group": "1_actions@7"
        },
        {
          "command": "diffchestrator.stash",
          "when": "viewItem == repo",
          "group": "1_actions@8"
        },
        {
          "command": "diffchestrator.browseFiles",
          "when": "viewItem == repo",
          "group": "1_actions@9"
        },
        {
          "command": "diffchestrator.grepInRepo",
          "when": "viewItem == repo",
          "group": "1_actions@10"
        },
        {
          "command": "diffchestrator.searchInRepo",
          "when": "viewItem == repo",
          "group": "1_actions@9"
        },
        {
          "command": "diffchestrator.openTerminal",
          "when": "viewItem == repo || viewItem == directory",
          "group": "2_tools@1"
        },
        {
          "command": "diffchestrator.openClaudeCode",
          "when": "viewItem == repo || viewItem == directory",
          "group": "2_tools@2"
        },
        {
          "command": "diffchestrator.yolo",
          "when": "viewItem == repo || viewItem == directory",
          "group": "2_tools@3"
        },
        {
          "command": "diffchestrator.yolonew",
          "when": "viewItem == repo || viewItem == directory",
          "group": "2_tools@4"
        },
        {
          "command": "diffchestrator.toggleFavorite",
          "when": "viewItem == repo || viewItem == directory",
          "group": "3_misc@1"
        },
        {
          "command": "diffchestrator.copyRepoInfo",
          "when": "viewItem == repo",
          "group": "3_misc@2"
        },
        {
          "command": "diffchestrator.openRemoteUrl",
          "when": "viewItem == repo",
          "group": "3_misc@3"
        },
        {
          "command": "diffchestrator.setRepoTag",
          "when": "viewItem == repo",
          "group": "3_misc@4"
        },
        {
          "command": "diffchestrator.revealInExplorer",
          "when": "viewItem == repo || viewItem == directory",
          "group": "3_misc@5"
        },
        {
          "command": "diffchestrator.selectRepo",
          "when": "viewItem == repo",
          "group": "3_misc@6"
        },
        {
          "command": "diffchestrator.stageFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.unstageFile",
          "when": "viewItem == file-staged",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.discardFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "inline@2"
        },
        {
          "command": "diffchestrator.discardFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "1_file@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "diffchestrator.scan",
        "key": "alt+d s",
        "mac": "alt+d s"
      },
      {
        "command": "diffchestrator.switchRepo",
        "key": "alt+d r",
        "mac": "alt+d r"
      },
      {
        "command": "diffchestrator.browseFiles",
        "key": "alt+d f",
        "mac": "alt+d f"
      },
      {
        "command": "diffchestrator.aiCommit",
        "key": "alt+d c",
        "mac": "alt+d c"
      },
      {
        "command": "diffchestrator.push",
        "key": "alt+d p",
        "mac": "alt+d p"
      },
      {
        "command": "diffchestrator.pull",
        "key": "alt+d u",
        "mac": "alt+d u"
      },
      {
        "command": "diffchestrator.openTerminal",
        "key": "alt+d t",
        "mac": "alt+d t"
      },
      {
        "command": "diffchestrator.openRootTerminal",
        "key": "alt+d shift+t",
        "mac": "alt+d shift+t"
      },
      {
        "command": "diffchestrator.openClaudeCode",
        "key": "alt+d l",
        "mac": "alt+d l"
      },
      {
        "command": "diffchestrator.yolo",
        "key": "alt+d y",
        "mac": "alt+d y"
      },
      {
        "command": "diffchestrator.yolonew",
        "key": "alt+d alt+y",
        "mac": "alt+d alt+y"
      },
      {
        "command": "diffchestrator.toggleChangedOnly",
        "key": "alt+d d",
        "mac": "alt+d d"
      },
      {
        "command": "diffchestrator.commitHistory",
        "key": "alt+d h",
        "mac": "alt+d h"
      },
      {
        "command": "diffchestrator.switchBranch",
        "key": "alt+d b",
        "mac": "alt+d b"
      },
      {
        "command": "diffchestrator.stash",
        "key": "alt+d a",
        "mac": "alt+d a"
      },
      {
        "command": "diffchestrator.toggleBlame",
        "key": "alt+d g",
        "mac": "alt+d g"

{
  "name": "diffchestrator",
  "displayName": "Diffchestrator",
  "description": "Multi-repo Git orchestration built for Claude Code — AI commits, diffs, and terminal integration",
  "version": "0.24.2",
  "publisher": "andrevops-com",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andrevops/diffchestrator"
  },
  "bugs": {
    "url": "https://github.com/Andrevops/diffchestrator/issues"
  },
  "homepage": "https://github.com/Andrevops/diffchestrator#readme",
  "keywords": [
    "git",
    "multi-repo",
    "claude",
    "diff",
    "monorepo"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/license/Andrevops/diffchestrator",
      "href": "https://github.com/Andrevops/diffchestrator/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "activationEvents": [
    "onView:diffchestrator.repos",
    "onView:diffchestrator.activeRepos",
    "onView:diffchestrator.favorites",
    "onView:diffchestrator.changedFiles",
    "onView:diffchestrator.scanRoots",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diffchestrator",
          "title": "Diffchestrator",
          "icon": "resources/icons/diffchestrator.svg"
        }
      ]
    },
    "views": {
      "diffchestrator": [
        {
          "id": "diffchestrator.activeRepos",
          "name": "Active Repos"
        },
        {
          "id": "diffchestrator.changedFiles",
          "name": "Changed Files"
        },
        {
          "id": "diffchestrator.favorites",
          "name": "Favorites"
        },
        {
          "id": "diffchestrator.repos",
          "name": "Repositories"
        },
        {
          "id": "diffchestrator.scanRoots",
          "name": "Scan Roots"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "diffchestrator.repos",
        "contents": "No repositories found.\n[Scan Directory](command:diffchestrator.scan)",
        "when": "!diffchestrator.hasRepos"
      },
      {
        "view": "diffchestrator.changedFiles",
        "contents": "Click a repository to see its changed files.",
        "when": "!diffchestrator.hasSelectedRepo"
      }
    ],
    "commands": [
      {
        "command": "diffchestrator.scan",
        "title": "Scan for Repositories",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.rescan",
        "title": "Rescan Repositories",
        "category": "Diffchestrator",
        "icon": "$(refresh)"
      },
      {
        "command": "diffchestrator.toggleChangedOnly",
        "title": "Toggle Changed Only",
        "category": "Diffchestrator",
        "icon": "$(filter)"
      },
      {
        "command": "diffchestrator.toggleFavorite",
        "title": "Toggle Favorite",
        "category": "Diffchestrator",
        "icon": "$(star)"
      },
      {
        "command": "diffchestrator.grepInRepo",
        "title": "Search in Repo",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.grepActiveRepos",
        "title": "Search Active Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.grepAllRepos",
        "title": "Search All Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.closeActiveRepo",
        "title": "Close Active Repo",
        "category": "Diffchestrator",
        "icon": "$(close)"
      },
      {
        "command": "diffchestrator.closePickedRepo",
        "title": "Close Active Repo (Pick)",
        "category": "Diffchestrator",
        "icon": "$(close-all)"
      },
      {
        "command": "diffchestrator.closeAllActiveRepos",
        "title": "Close All Active Repos",
        "category": "Diffchestrator",
        "icon": "$(close-all)"
      },
      {
        "command": "diffchestrator.nextChangedFile",
        "title": "Next Changed File",
        "category": "Diffchestrator",
        "icon": "$(arrow-down)"
      },
      {
        "command": "diffchestrator.prevChangedFile",
        "title": "Previous Changed File",
        "category": "Diffchestrator",
        "icon": "$(arrow-up)"
      },
      {
        "command": "diffchestrator.searchInRepo",
        "title": "Open Repo in New Window",
        "category": "Diffchestrator",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "diffchestrator.favoriteCurrent",
        "title": "Favorite Current Repo",
        "category": "Diffchestrator",
        "icon": "$(star)"
      },
      {
        "command": "diffchestrator.cycleActiveRepo",
        "title": "Cycle Active Repo",
        "category": "Diffchestrator",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "diffchestrator.viewDiff",
        "title": "View Diff",
        "category": "Diffchestrator",
        "icon": "$(diff)"
      },
      {
        "command": "diffchestrator.viewMultiRepoDiff",
        "title": "View Multi-Repo Diff",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.stageFile",
        "title": "Stage File",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageFile",
        "title": "Unstage File",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.stageAll",
        "title": "Stage All",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageAll",
        "title": "Unstage All",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.commit",
        "title": "Commit",
        "category": "Diffchestrator",
        "icon": "$(check)"
      },
      {
        "command": "diffchestrator.push",
        "title": "Push",
        "category": "Diffchestrator",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "diffchestrator.pull",
        "title": "Pull",
        "category": "Diffchestrator",
        "icon": "$(cloud-download)"
      },
      {
        "command": "diffchestrator.aiCommit",
        "title": "AI Commit (Claude)",
        "category": "Diffchestrator",
        "icon": "$(sparkle)"
      },
      {
        "command": "diffchestrator.bulkCommit",
        "title": "Bulk Commit Selected Repos",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.bulkPush",
        "title": "Bulk Push Selected Repos",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.openClaudeCode",
        "title": "Open Claude Code",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.yolo",
        "title": "Yolo (Claude Sandbox)",
        "category": "Diffchestrator",
        "icon": "$(zap)"
      },
      {
        "command": "diffchestrator.searchFiles",
        "title": "Search Files Across Repos",
        "category": "Diffchestrator",
        "icon": "$(search)"
      },
      {
        "command": "diffchestrator.browseFiles",
        "title": "Browse Files in Repo",
        "category": "Diffchestrator",
        "icon": "$(file-directory)"
      },
      {
        "command": "diffchestrator.switchRepo",
        "title": "Switch Repo",
        "category": "Diffchestrator",
        "icon": "$(repo)"
      },
      {
        "command": "diffchestrator.openTerminal",
        "title": "Open Terminal",
        "category": "Diffchestrator",
        "icon": "$(terminal)"
      },
      {
        "command": "diffchestrator.selectRepo",
        "title": "Select / Deselect Repo",
        "category": "Diffchestrator",
        "icon": "$(check)"
      },
      {
        "command": "diffchestrator.clearSelection",
        "title": "Clear Selection",
        "category": "Diffchestrator"
      },
      {
        "command": "diffchestrator.commitHistory",
        "title": "Commit History",
        "category": "Diffchestrator",
        "icon": "$(history)"
      },
      {
        "command": "diffchestrator.discardFile",
        "title": "Discard Changes",
        "category": "Diffchestrator",
        "icon": "$(discard)"
      },
      {
        "command": "diffchestrator.discardAll",
        "title": "Discard All Changes",
        "category": "Diffchestrator",
        "icon": "$(discard)"
      },
      {
        "command": "diffchestrator.stageCurrentFile",
        "title": "Stage This File",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.unstageCurrentFile",
        "title": "Unstage This File",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      },
      {
        "command": "diffchestrator.switchBranch",
        "title": "Switch Branch",
        "category": "Diffchestrator",
        "icon": "$(git-branch)"
      },
      {
        "command": "diffchestrator.stash",
        "title": "Stash Management",
        "category": "Diffchestrator",
        "icon": "$(archive)"
      },
      {
        "command": "diffchestrator.toggleBlame",
        "title": "Toggle Inline Blame",
        "category": "Diffchestrator",
        "icon": "$(eye)"
      },
      {
        "command": "diffchestrator.switchRoot",
        "title": "Switch Scan Root",
        "category": "Diffchestrator",
        "icon": "$(folder-opened)"
      },
      {
        "command": "diffchestrator.addScanRoot",
        "title": "Add Scan Root",
        "category": "Diffchestrator",
        "icon": "$(add)"
      },
      {
        "command": "diffchestrator.removeScanRoot",
        "title": "Remove Scan Root",
        "category": "Diffchestrator",
        "icon": "$(remove)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "diffchestrator.prevChangedFile",
          "group": "navigation@1",
          "when": "diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.nextChangedFile",
          "group": "navigation@2",
          "when": "diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.stageCurrentFile",
          "group": "navigation@3",
          "when": "resourceScheme == file && diffchestrator.hasSelectedRepo"
        },
        {
          "command": "diffchestrator.unstageCurrentFile",
          "group": "navigation@4",
          "when": "resourceScheme == file && diffchestrator.hasSelectedRepo"
        }
      ],
      "view/title": [
        {
          "command": "diffchestrator.scan",
          "when": "view == diffchestrator.repos",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.rescan",
          "when": "view == diffchestrator.repos",
          "group": "navigation@2"
        },
        {
          "command": "diffchestrator.toggleChangedOnly",
          "when": "view == diffchestrator.repos",
          "group": "navigation@3"
        },
        {
          "command": "diffchestrator.stageAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@1"
        },
        {
          "command": "diffchestrator.unstageAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@2"
        },
        {
          "command": "diffchestrator.discardAll",
          "when": "view == diffchestrator.changedFiles && diffchestrator.hasSelectedRepo",
          "group": "navigation@3"
        },
        {
          "command": "diffchestrator.addScanRoot",
          "when": "view == diffchestrator.scanRoots",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "diffchestrator.removeScanRoot",
          "when": "viewItem == scanRoot",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.viewDiff",
          "when": "viewItem == repo",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.commit",
          "when": "viewItem == repo",
          "group": "inline@2"
        },
        {
          "command": "diffchestrator.push",
          "when": "viewItem == repo",
          "group": "1_actions@1"
        },
        {
          "command": "diffchestrator.pull",
          "when": "viewItem == repo",
          "group": "1_actions@2"
        },
        {
          "command": "diffchestrator.aiCommit",
          "when": "viewItem == repo",
          "group": "1_actions@3"
        },
        {
          "command": "diffchestrator.commitHistory",
          "when": "viewItem == repo",
          "group": "1_actions@4"
        },
        {
          "command": "diffchestrator.switchBranch",
          "when": "viewItem == repo",
          "group": "1_actions@5"
        },
        {
          "command": "diffchestrator.stash",
          "when": "viewItem == repo",
          "group": "1_actions@6"
        },
        {
          "command": "diffchestrator.browseFiles",
          "when": "viewItem == repo",
          "group": "1_actions@7"
        },
        {
          "command": "diffchestrator.grepInRepo",
          "when": "viewItem == repo",
          "group": "1_actions@8"
        },
        {
          "command": "diffchestrator.searchInRepo",
          "when": "viewItem == repo",
          "group": "1_actions@9"
        },
        {
          "command": "diffchestrator.openTerminal",
          "when": "viewItem == repo",
          "group": "2_tools@1"
        },
        {
          "command": "diffchestrator.openClaudeCode",
          "when": "viewItem == repo",
          "group": "2_tools@2"
        },
        {
          "command": "diffchestrator.yolo",
          "when": "viewItem == repo",
          "group": "2_tools@3"
        },
        {
          "command": "diffchestrator.toggleFavorite",
          "when": "viewItem == repo || viewItem == directory",
          "group": "3_misc@1"
        },
        {
          "command": "diffchestrator.selectRepo",
          "when": "viewItem == repo",
          "group": "3_misc@2"
        },
        {
          "command": "diffchestrator.stageFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.unstageFile",
          "when": "viewItem == file-staged",
          "group": "inline@1"
        },
        {
          "command": "diffchestrator.discardFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "inline@2"
        },
        {
          "command": "diffchestrator.discardFile",
          "when": "viewItem == file-unstaged || viewItem == file-untracked",
          "group": "1_file@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "diffchestrator.scan",
        "key": "ctrl+d s",
        "mac": "cmd+d s"
      },
      {
        "command": "diffchestrator.switchRepo",
        "key": "ctrl+d r",
        "mac": "cmd+d r"
      },
      {
        "command": "diffchestrator.browseFiles",
        "key": "ctrl+d f",
        "mac": "cmd+d f"
      },
      {
        "command": "diffchestrator.aiCommit",
        "key": "ctrl+d c",
        "mac": "cmd+d c"
      },
      {
        "command": "diffchestrator.push",
        "key": "ctrl+d p",
        "mac": "cmd+d p"
      },
      {
        "command": "diffchestrator.pull",
        "key": "ctrl+d u",
        "mac": "cmd+d u"
      },
      {
        "command": "diffchestrator.openTerminal",
        "key": "ctrl+d t",
        "mac": "cmd+d t"
      },
      {
        "command": "diffchestrator.openClaudeCode",
        "key": "ctrl+d l",
        "mac": "cmd+d l"
      },
      {
        "command": "diffchestrator.yolo",
        "key": "ctrl+d y",
        "mac": "cmd+d y"
      },
      {
        "command": "diffchestrator.toggleChangedOnly",
        "key": "ctrl+d d",
        "mac": "cmd+d d"
      },
      {
        "command": "diffchestrator.commitHistory",
        "key": "ctrl+d h",
        "mac": "cmd+d h"
      },
      {
        "command": "diffchestrator.switchBranch",
        "key": "ctrl+d b",
        "mac": "cmd+d b"
      },
      {
        "command": "diffchestrator.stash",
        "key": "ctrl+d a",
        "mac": "cmd+d a"
      },
      {
        "command": "diffchestrator.toggleBlame",
        "key": "ctrl+d g",
        "mac": "cmd+d g"
      },
      {
        "command": "diffchestrator.favoriteCurrent",
        "key": "ctrl+d e",
        "mac": "cmd+d e"
      },
      {
        "command": "diffchestrator.grepInRepo",
        "key": "ctrl+d /",
        "mac": "cmd+d /"
      },
      {
        "command": "diffchestrator.grepActiveRepos",
        "key": "ctrl+d .",
        "mac": "cmd+d ."
      },
      {
        "command": "diffchestrator.grepAllRepos",
        "key": "ctrl+d shift+/",
        "mac": "cmd+d shift+/"
      },
      {
        "command": "diffchestrator.searchInRepo",
        "key": "ctrl+d w",
        "mac": "cmd+d w"
      },
      {
        "command": "diffchestrator.cycleActiveRepo",
        "key": "ctrl+d tab",
        "mac": "cmd+d tab"
      },
      {
        "command": "diffchestrator.closeActiveRepo",
        "key": "ctrl+d q",
        "mac": "cmd+d q"
      },
      {
        "command": "diffchestrator.closePickedRepo",
        "key": "ctrl+d shift+q",
        "mac": "cmd+d shift+q"
      },
      {
        "command": "diffchestrator.closeAllActiveRepos",
        "key": "ctrl+d shift+tab",
        "mac": "cmd+d shift+tab"
      },
      {
        "command": "diffchestrator.nextChangedFile",
        "key": "ctrl+d n",
        "mac": "cmd+d n"
      },
      {
        "command": "diffchestrator.prevChangedFile",
        "key": "ctrl+d shift+n",
        "mac": "cmd+d shift+n"
      }
    ],
    "configuration": {
      "title": "Diffchestrator",
      "properties": {
        "diffchestrator.scanRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Root directories to scan for Git repositories"
        },
        "diffchestrator.scanMaxDepth": {
          "type": "number",
          "default": 6,
          "description": "Maximum directory depth when scanning for repositories"
        },
        "diffchestrator.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan for repositories when VS Code starts"
        },
        "diffchestrator.changedOnlyDefault": {
          "type": "boolean",
          "default": false,
          "description": "Show only repos with changes by default"
        },
        "diffchestrator.autoRefreshInterval": {
          "type": "number",
          "default": 10,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        },
        "diffchestrator.favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Favorited repository paths"
        },
        "diffchestrator.claudePermissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "full"
          ],
          "default": "acceptEdits",
          "description": "Permission mode for Claude Code AI commits"
        },
        "diffchestrator.scanExtraSkipDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directory names to skip during scanning"
        },
        "diffchestrator.showInlineBlame": {
          "type": "boolean",
          "default": true,
          "description": "Show inline git blame annotation on the current line"
        }
      }
    }
  },
  "scripts": {
    "build:webview": "cd webview-ui && npm run build",
    "compile": "node esbuild.mjs",
    "build": "npm run build:webview && node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
